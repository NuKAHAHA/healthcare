# ============================================================
# Healthcare API — Environment Configuration
# ============================================================
# Copy to .env and fill in real values. NEVER commit .env.
# Generate secrets:
#   JWT_SECRET  : openssl rand -hex 64
#   DB_PASSWORD : openssl rand -hex 32
#   REDIS_PASSWORD: openssl rand -hex 32
# ============================================================

APP_ENV=development

# ── Server ──────────────────────────────────────────────────
SERVER_PORT=8080
MAX_BODY_SIZE=1048576
REQUEST_TIMEOUT=30

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32
DB_NAME=healthcare
# Use 'require' in production; 'disable' only for local dev
DB_SSL_MODE=disable

# ── Redis ────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32
REDIS_DB=0

# ── JWT ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 64  (must be ≥ 32 chars)
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64
JWT_ACCESS_EXPIRE_MIN=5
JWT_REFRESH_EXPIRE_DAY=7

# ── Rate limiting ─────────────────────────────────────────────
# Global: requests per minute per IP for all routes
RATE_LIMIT_GLOBAL_RPM=100
# Login: max failed attempts per window before block
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MIN=15
LOGIN_BLOCK_MIN=15

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
